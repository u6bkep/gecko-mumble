
# .env example file for the Mumble server
SLICE_NAME="MumbleServerv1.5.735.ice"
MURMUR_CONNECT_URL="http://www.mumble.info/"
MUMBLE_CONFIG_icesecretread="password"
# --- channel-push authentication (Authentik OIDC) ---
CVP_AUTHENTIK_URL="https://auth.example.com/"
CVP_OIDC_SLUG="mumble-channel-viewer"
CVP_OIDC_CLIENT_ID="<oauth2 provider client id>"
CVP_OIDC_CLIENT_SECRET="<oauth2 provider client secret>"
CVP_PUBLIC_URL="https://mumble.example.com"   # public URL served by Caddy
#CVP_REQUIRED_GROUP="mumble-viewers"   # optional: restrict access to one group
# in-app TLS (ONLY for a standalone build --features tls; not used behind Caddy)
CVP_TLS_CERT="/etc/letsencrypt/live/mumble.example.com/fullchain.pem"
CVP_TLS_KEY="/etc/letsencrypt/live/mumble.example.com/privkey.pem"
